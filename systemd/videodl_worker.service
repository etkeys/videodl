[Unit]
Description=Runs the background worker for Video DL application.
After=docker.service
Requires=docker.service
StartLimitBurst=5
StartLimitIntervalSec=10800

# To restart the service once max failed attempts reached
# systemctl reset-failed
# systemctl restart

[Service]
User=videodl
ExecStart={{ REMOTE_APP_DIR }}/venv/bin/python3 {{ REMOTE_APP_DIR }}/src/worker_run.py
Environment=PYTHONUNBUFFERED=1
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target